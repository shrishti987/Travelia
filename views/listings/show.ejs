<% layout("layouts/boilerplate") %>

<div class="row mt-4">

  <!-- TITLE -->
  <div class="col-8 offset-2">
    <h2 class="fw-bold"><%= listing.title %></h2>
  </div>

  <!-- IMAGE CARD -->
  <div class="card col-8 offset-2 show-card mt-3">

    <img 
      src="<%= listing.image?.url || 'https://via.placeholder.com/800' %>" 
      class="card-img-top show-img"
      alt="listing_image"
    >

    <div class="card-body">

      <!-- 🚨 FRAUD WARNING -->
      <% if (listing.isFraud) { %>
        <p class="text-danger fw-bold">
          🚨 Suspicious Listing: <%= listing.fraudReason %>
        </p>
      <% } else { %>
        <span class="badge bg-success">✔ Verified Listing</span>
      <% } %>

      <p class="card-text mt-3">

        <%= listing.description %><br><br>

        <b>
          ₹ <%= Number(listing.price).toLocaleString("en-IN") %> / night
        </b><br><br>

        📍 <%= listing.location %>, <%= listing.country %>

      </p>

    </div>

  </div>

  <!-- ✈️ BOOKING FORM -->
  <div class="col-8 offset-2 mt-4">

    <div class="card p-3 shadow-sm">
      <h4>Book this stay ✈️</h4>

      <form action="/listings/<%= listing._id %>/book" method="POST">

        <div class="row">

          <div class="col">
            <label>Check In</label>
            <input type="date" name="checkIn" class="form-control" required>
          </div>

          <div class="col">
            <label>Check Out</label>
            <input type="date" name="checkOut" class="form-control" required>
          </div>

        </div>

        <button 
          class="btn btn-success mt-3 w-100">
          Book Now
        </button>

      </form>
    </div>

  </div>

  <!-- LOCATION MAP -->
  <div class="col-8 offset-2 mt-4">
    <h4>Location Map 📍</h4>
    <div id="map" style="height: 300px; border-radius: 10px;"></div>
  </div>

  <!-- REVIEWS -->
  <div class="col-8 offset-2 mt-4">

    <h4>Reviews ⭐</h4>

    <!-- ADD REVIEW -->
    <form action="/listings/<%= listing._id %>/reviews" method="POST">

      <div class="mb-3">
        <label>Rating</label>
        <input type="number" name="review[rating]" min="1" max="5" class="form-control" required>
      </div>

      <div class="mb-3">
        <label>Comment</label>
        <textarea name="review[comment]" class="form-control" required></textarea>
      </div>

      <button class="btn btn-dark">Submit Review</button>

    </form>

    <!-- REVIEW LIST -->
    <% if (listing.reviews.length === 0) { %>
      <p class="mt-3 text-muted">No reviews yet 😢</p>
    <% } %>

    <% listing.reviews.forEach((review) => { %>

      <div class="card mt-3">
        <div class="card-body">
          ⭐ <b><%= review.rating %> / 5</b>
          <p class="mt-2"><%= review.comment %></p>
        </div>
      </div>

    <% }) %>

  </div>

</div>

<!-- MAP SCRIPT -->
<script>
document.addEventListener("DOMContentLoaded", function () {

  var map = L.map('map').setView([30.3165, 78.0322], 13);

  L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19
  }).addTo(map);

  var marker = L.marker([30.3165, 78.0322]).addTo(map);

  marker.bindPopup("<b><%= listing.title %></b>").openPopup();

});
</script>